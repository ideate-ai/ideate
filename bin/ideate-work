#!/usr/bin/env node
// plugin/bin/ideate-work — executable edge for the v3 work-state CLI
// (WI-303; docs/spikes/v3-work-delegation.md §3.5: the eleven-verb surface,
// mirrored here as the CLI's second transport, plus the CLI-only `sweep`
// subcommand — hooks invoke this via ${CLAUDE_PLUGIN_ROOT}/bin/ideate-work).
//
// Thin loader only: all logic lives in src/cli/ideate-work.ts (compiled to
// dist/cli/ideate-work.js). Dynamic import keeps this wrapper working
// whether Node loads this extensionless file as CommonJS or as an ES module.
//
// Load-failure exit codes mirror the CLI's documented split: the hook-invoked
// `sweep` subcommand exits 0 even when the compiled CLI is missing — a
// broken install must never look like a hook failure to the host — while
// every direct-use subcommand exits 1 so scripts see the error.
const HOOK_SUBCOMMANDS = new Set(['sweep']);
import('../dist/cli/ideate-work.js')
  .then((mod) => {
    process.exitCode = mod.main(process.argv.slice(2));
  })
  .catch((err) => {
    console.error(
      'ideate-work: failed to run the compiled CLI (dist/cli/ideate-work.js). Run `pnpm build` first.',
    );
    console.error(err instanceof Error ? err.message : String(err));
    process.exitCode = HOOK_SUBCOMMANDS.has(process.argv[2]) ? 0 : 1;
  });
